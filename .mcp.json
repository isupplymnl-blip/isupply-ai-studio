{
  "mcpServers": {
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ],
      "type": "stdio"
    },
    "afd": {
      "command": "bun",
      "args": [
        "run",
        "src/daemon/server.ts",
        "--mcp"
      ]
    }
  }
}