# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# Electron
/dist-electron/
/electron-cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local file storage (generated images + reference assets)
/public/generated/
/public/uploads/
/data/
